<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Zoda — Profil pescar</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{background:#0a0f1a;color:#f1f5f9;font-family:'Segoe UI',system-ui,sans-serif;font-size:14px;min-height:100vh;}
::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-track{background:#0a0f1a;}
::-webkit-scrollbar-thumb{background:#1e293b;border-radius:3px;}

/* HEADER */
#hdr{background:rgba(10,15,26,.97);border-bottom:1px solid #1e293b;position:sticky;top:0;z-index:100;backdrop-filter:blur(8px);}
#hdr-in{max-width:900px;margin:0 auto;display:flex;align-items:center;gap:12px;padding:0 14px;height:52px;}
.logo{font-size:16px;font-weight:800;color:#a3e635;text-decoration:none;white-space:nowrap;}
.back-btn{display:flex;align-items:center;gap:6px;background:#0a0f1a;border:1px solid #1e293b;border-radius:8px;color:#94a3b8;font-weight:600;cursor:pointer;text-decoration:none;white-space:nowrap;flex-shrink:0;margin-left:auto;padding:5px 12px;font-size:12px;}
.back-btn:hover{border-color:#a3e635;color:#a3e635;}

/* LOADING */
#loading-screen{position:fixed;inset:0;background:#0a0f1a;display:flex;align-items:center;justify-content:center;z-index:9000;flex-direction:column;gap:16px;}
.spinner{width:40px;height:40px;border:3px solid #1e293b;border-top-color:#a3e635;border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}

/* ERROR */
#error-screen{display:none;position:fixed;inset:0;background:#0a0f1a;align-items:center;justify-content:center;flex-direction:column;gap:12px;z-index:9000;}

/* PAGE */
#page{display:none;max-width:900px;margin:0 auto;padding:24px 14px 60px;}

/* HERO CARD */
.hero-card{background:#111827;border:1px solid #1e293b;border-radius:18px;padding:28px 24px;margin-bottom:20px;display:flex;align-items:center;gap:20px;position:relative;overflow:hidden;}
.hero-card::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at top left,rgba(163,230,53,.04) 0%,transparent 60%);pointer-events:none;}
.hero-avatar{width:80px;height:80px;border-radius:50%;background:#1a6b3a;border:3px solid #166534;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:900;color:#a3e635;flex-shrink:0;overflow:hidden;}
.hero-avatar img{width:100%;height:100%;object-fit:cover;}
.hero-info{flex:1;min-width:0;}
.hero-name{font-size:22px;font-weight:900;color:#f1f5f9;margin-bottom:4px;}
.hero-zoda{font-size:12px;color:#4b5563;font-family:monospace;margin-bottom:10px;}
.hero-stele{display:flex;align-items:center;gap:8px;}
.stele-badge{background:#1c1500;border:1px solid #92400e;border-radius:8px;padding:6px 14px;display:flex;align-items:center;gap:6px;}
.stele-num{font-size:22px;font-weight:900;color:#f59e0b;}
.stele-lbl{font-size:11px;color:#92400e;font-weight:700;letter-spacing:.04em;}
.stele-breakdown{font-size:10px;color:#4b5563;line-height:1.8;}

/* TABS */
.tabs{display:flex;background:#111827;border:1px solid #1e293b;border-radius:12px;padding:4px;margin-bottom:16px;gap:4px;}
.tab{flex:1;background:transparent;border:none;color:#4b5563;font-size:12px;font-weight:700;padding:9px;border-radius:8px;cursor:pointer;transition:all .2s;letter-spacing:.03em;}
.tab.active{background:#1a6b3a;color:#a3e635;}

/* SECTION */
.section{background:#111827;border:1px solid #1e293b;border-radius:14px;margin-bottom:12px;overflow:hidden;}
.section-hdr{display:flex;align-items:center;gap:10px;padding:14px 18px;border-bottom:1px solid #1e293b;}
.section-icon{font-size:16px;}
.section-title{font-size:13px;font-weight:800;color:#f1f5f9;flex:1;}
.section-count{font-size:10px;background:#1a3020;color:#a3e635;padding:2px 8px;border-radius:10px;font-weight:700;}
.section-body{padding:0;}

/* REALIZARE ROW */
.rez-row{display:flex;align-items:center;gap:12px;padding:12px 18px;border-bottom:1px solid #0f172a;transition:background .15s;}
.rez-row:last-child{border-bottom:none;}
.rez-row:hover{background:#0d1520;}
.rez-icon-wrap{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
.rez-icon-wrap.gold{background:#1c1500;border:1px solid #92400e;}
.rez-icon-wrap.green{background:#0d1f12;border:1px solid #1a6b3a;}
.rez-icon-wrap.blue{background:#0c1a2e;border:1px solid #1e40af;}
.rez-icon-wrap.gray{background:#0f172a;border:1px solid #1e293b;}
.rez-body{flex:1;min-width:0;}
.rez-title{font-size:13px;font-weight:700;color:#e2e8f0;margin-bottom:2px;}
.rez-meta{font-size:11px;color:#4b5563;line-height:1.6;}
.rez-star{font-size:11px;color:#f59e0b;font-weight:800;flex-shrink:0;white-space:nowrap;}
.rez-date{font-size:10px;color:#334155;margin-top:2px;}

/* TRECUT row — mai subtil */
.rez-row.trecut .rez-title{color:#475569;}
.rez-row.trecut .rez-icon-wrap{opacity:.5;}
.rez-row.trecut .rez-star{color:#64748b;}

/* EMPTY */
.empty-state{padding:32px 20px;text-align:center;}
.empty-icon{font-size:40px;margin-bottom:10px;}
.empty-title{font-size:13px;font-weight:700;color:#334155;margin-bottom:4px;}
.empty-sub{font-size:11px;color:#1e293b;line-height:1.6;}

/* DESKTOP */
@media(min-width:769px){
  #hdr-in{padding:0 24px;height:62px;}
  .logo{font-size:18px;}
  #page{padding:32px 24px 80px;}
  .hero-card{padding:32px 28px;gap:24px;}
  .hero-avatar{width:96px;height:96px;font-size:34px;}
  .hero-name{font-size:26px;}
  .tabs{max-width:360px;}
}
</style>
</head>
<body>

<div id="loading-screen">
  <div class="spinner"></div>
  <div style="color:#64748b;font-size:13px;">Se încarcă profilul...</div>
</div>

<div id="error-screen">
  <div style="font-size:48px;margin-bottom:12px;">🎣</div>
  <div style="font-size:16px;font-weight:700;color:#334155;" id="error-msg">Pescar negăsit</div>
  <a href="index.html" style="margin-top:16px;color:#a3e635;font-size:13px;text-decoration:none;">← Înapoi la hartă</a>
</div>

<div id="hdr" style="display:none;">
  <div id="hdr-in">
    <a href="index.html" class="logo">Zoda</a>
    <span style="font-size:12px;color:#4b5563;" id="hdr-subtitle">Profil pescar</span>
    <a href="javascript:history.back()" class="back-btn">← Înapoi</a>
  </div>
</div>

<div id="page">

  <!-- HERO -->
  <div class="hero-card">
    <div class="hero-avatar" id="hero-avatar"></div>
    <div class="hero-info">
      <div class="hero-name" id="hero-name">—</div>
      <div class="hero-zoda" id="hero-zoda">—</div>
      <div class="hero-stele">
        <div class="stele-badge">
          <span class="stele-num" id="hero-stele-num">0</span>
          <span class="stele-lbl">STELE</span>
        </div>
        <div class="stele-breakdown" id="hero-stele-breakdown"></div>
      </div>
    </div>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <button class="tab active" onclick="switchTab('active')" id="tab-active">⚡ Active</button>
    <button class="tab" onclick="switchTab('trecute')" id="tab-trecute">📜 Trecute</button>
  </div>

  <!-- ACTIVE -->
  <div id="panel-active">
    <div id="active-list"></div>
    <div class="empty-state" id="active-empty" style="display:none;">
      <div class="empty-icon">🎣</div>
      <div class="empty-title">Nicio realizare activă</div>
      <div class="empty-sub">Realizările apar când pescarul deține<br/>un record de stand sau e în top 10.</div>
    </div>
  </div>

  <!-- TRECUTE -->
  <div id="panel-trecute" style="display:none;">
    <div id="trecute-list"></div>
    <div class="empty-state" id="trecute-empty" style="display:none;">
      <div class="empty-icon">📜</div>
      <div class="empty-title">Nicio realizare trecută</div>
      <div class="empty-sub">Realizările pierdute vor apărea aici.</div>
    </div>
  </div>

</div><!-- /#page -->

<script>
const SUPA_URL = 'https://emnesflrzptqfttlzusw.supabase.co';
const SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVtbmVzZmxyenB0cWZ0dGx6dXN3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE5NTc5NDUsImV4cCI6MjA5NzUzMzk0NX0.LoR6peujcdm1SLZ8SUSdtSH8wDa_ptCUEYT3qtAPZXk';
const sb = supabase.createClient(SUPA_URL, SUPA_KEY, {
  auth: { persistSession: true, autoRefreshToken: true, storageKey: 'zoda-auth' }
});

function fmtDate(str) {
  if (!str) return '';
  const d = new Date(str);
  return d.toLocaleDateString('ro-RO', { day: 'numeric', month: 'short', year: 'numeric' });
}

function switchTab(tab) {
  document.getElementById('panel-active').style.display  = tab === 'active'   ? 'block' : 'none';
  document.getElementById('panel-trecute').style.display = tab === 'trecute'  ? 'block' : 'none';
  document.getElementById('tab-active').classList.toggle('active',  tab === 'active');
  document.getElementById('tab-trecute').classList.toggle('active', tab === 'trecute');
}

function realizareRow(opts) {
  const { iconWrapClass, icon, title, meta, star, date, trecut, link } = opts;
  const cls = 'rez-row' + (trecut ? ' trecut' : '');
  const inner = `
    <div class="rez-icon-wrap ${iconWrapClass}">${icon}</div>
    <div class="rez-body">
      <div class="rez-title">${title}</div>
      <div class="rez-meta">${meta}</div>
      ${date ? `<div class="rez-date">📅 ${date}</div>` : ''}
    </div>
    ${star ? `<div class="rez-star">⭐ +1</div>` : ''}`;
  if (link) return `<a href="${link}" class="${cls}" style="text-decoration:none;display:flex;align-items:center;gap:12px;padding:12px 18px;border-bottom:1px solid #0f172a;transition:background .15s;">${inner}</a>`;
  return `<div class="${cls}">${inner}</div>`;
}

async function boot() {
  const zodaId = new URLSearchParams(location.search).get('id');
  if (!zodaId) { showError('Link invalid — lipsește ID-ul pescarului.'); return; }

  // 1. Profil pescar
  const { data: profile, error: profErr } = await sb
    .from('user_profiles')
    .select('username, avatar_url, zoda_id, created_at')
    .eq('zoda_id', zodaId)
    .is('deleted_at', null)
    .single();

  if (profErr || !profile) { showError('Pescarul nu a fost găsit sau contul a fost șters.'); return; }

  // 2. Stele totale
  const { data: steleData } = await sb
    .from('stele_totale')
    .select('*')
    .eq('zoda_id', zodaId)
    .single();

  // 3. Toate stelele din log (pentru realizări trecute + active)
  const { data: steleLog } = await sb
    .from('stele_log')
    .select('id, tip, referinta, balta_id, created_at, balti(nume)')
    .eq('zoda_id', zodaId)
    .order('created_at', { ascending: false });

  // 4. Standuri unde pescarul DEȚINE ACUM recordul
  const { data: recorduriActive } = await sb
    .from('standuri')
    .select('id, nume, rec_kg, rec_data, balta_id, balti(nume, judet)')
    .eq('rec_pescar_id', zodaId);

  // 5. Top 10 lunar istoric
  const { data: top10Istoric } = await sb
    .from('top10_lunar_istoric')
    .select('luna, pozitie, kg_total, balta_id, balti(nume)')
    .eq('zoda_id', zodaId)
    .order('luna', { ascending: false });

  renderHero(profile, steleData);
  renderRealizari(steleLog || [], recorduriActive || [], top10Istoric || []);

  document.getElementById('loading-screen').style.display = 'none';
  document.getElementById('hdr').style.display = 'block';
  document.getElementById('page').style.display = 'block';
  document.title = 'Zoda — ' + (profile.username || zodaId);
  document.getElementById('hdr-subtitle').textContent = profile.username || zodaId;
}

function renderHero(profile, steleData) {
  const username  = profile.username || profile.zoda_id;
  const avatarUrl = profile.avatar_url || '';
  const initials  = username.slice(0, 2).toUpperCase();

  const avatarEl = document.getElementById('hero-avatar');
  if (avatarUrl) {
    avatarEl.innerHTML = `<img src="${avatarUrl}" alt="avatar"/>`;
  } else {
    avatarEl.textContent = initials;
  }

  document.getElementById('hero-name').textContent = username;
  document.getElementById('hero-zoda').textContent = profile.zoda_id;

  const total = steleData?.total_stele || 0;
  document.getElementById('hero-stele-num').textContent = total;

  const rs  = steleData?.stele_record_stand  || 0;
  const t10 = steleData?.stele_top10_lunar   || 0;
  const hof = steleData?.stele_hall_of_fame  || 0;
  const parts = [];
  if (rs)  parts.push(`🏅 ${rs} record${rs !== 1 ? 'uri' : ''} stand`);
  if (t10) parts.push(`📅 ${t10} top 10 lunar`);
  if (hof) parts.push(`🏆 ${hof} Hall of Fame`);
  document.getElementById('hero-stele-breakdown').innerHTML = parts.join('<br/>') ||
    '<span style="color:#1e293b;">Nicio stea câștigată încă</span>';
}

function renderRealizari(steleLog, recorduriActive, top10Istoric) {
  const activeList   = document.getElementById('active-list');
  const trecuteList  = document.getElementById('trecute-list');

  // Index standuri active după id
  const activeStandIds = new Set((recorduriActive).map(s => String(s.id)));

  // Index top10 lunar după luna+balta (cele mai recente 3 luni = active, restul trecute)
  const luniRecente = [...new Set(top10Istoric.map(t => t.luna))].slice(0, 3);
  const luniRecenteSet = new Set(luniRecente);

  let activeHtml   = '';
  let trecuteHtml  = '';

  // ── RECORDURI STAND ACTIVE ────────────────────────────────────────────────
  recorduriActive.forEach(s => {
    const baltaNume = s.balti?.nume || '—';
    const judet = s.balti?.judet ? ` · ${s.balti.judet}` : '';
    // Găsim steaua din log pentru data activării
    const stea = steleLog.find(l => l.tip === 'record_stand' && l.referinta === String(s.id));
    activeHtml += realizareRow({
      iconWrapClass: 'gold',
      icon: '🏆',
      title: `Record Stand — ${s.nume}`,
      meta: `${baltaNume}${judet}${s.rec_kg ? ' · <strong style="color:#a3e635;">' + s.rec_kg + ' kg</strong>' : ''}`,
      star: true,
      date: stea ? 'Activ din ' + fmtDate(stea.created_at) : '',
      trecut: false,
      link: `balta.html?id=${s.balta_id}`,
    });
  });

  // ── TOP 10 LUNAR ACTIVE (ultimele 3 luni) ─────────────────────────────────
  top10Istoric
    .filter(t => luniRecenteSet.has(t.luna))
    .forEach(t => {
      const [an, luna] = t.luna.split('-');
      const lunaFmt = new Date(parseInt(an), parseInt(luna) - 1).toLocaleDateString('ro-RO', { month: 'long', year: 'numeric' });
      const baltaNume = t.balti?.nume || '—';
      activeHtml += realizareRow({
        iconWrapClass: 'green',
        icon: '📅',
        title: `Top 10 lunar — Locul ${t.pozitie}`,
        meta: `${baltaNume} · ${lunaFmt}${t.kg_total ? ' · ' + parseFloat(t.kg_total).toFixed(1) + ' kg total' : ''}`,
        star: true,
        date: '',
        trecut: false,
        link: `balta.html?id=${t.balta_id}`,
      });
    });

  // ── HALL OF FAME — PLACEHOLDER ────────────────────────────────────────────
  // (se activează când implementăm HOF per baltă)

  // ── RECORDURI STAND TRECUTE ───────────────────────────────────────────────
  // Stelele de tip record_stand pentru standuri pe care nu le mai deține
  steleLog
    .filter(l => l.tip === 'record_stand' && !activeStandIds.has(l.referinta))
    .forEach(l => {
      const baltaNume = l.balti?.nume || '—';
      trecuteHtml += realizareRow({
        iconWrapClass: 'gray',
        icon: '🏆',
        title: `Record Stand — deținut anterior`,
        meta: `${baltaNume}`,
        star: false,
        date: 'Câștigat la ' + fmtDate(l.created_at),
        trecut: true,
        link: null,
      });
    });

  // ── TOP 10 LUNAR TRECUTE ──────────────────────────────────────────────────
  top10Istoric
    .filter(t => !luniRecenteSet.has(t.luna))
    .forEach(t => {
      const [an, luna] = t.luna.split('-');
      const lunaFmt = new Date(parseInt(an), parseInt(luna) - 1).toLocaleDateString('ro-RO', { month: 'long', year: 'numeric' });
      const baltaNume = t.balti?.nume || '—';
      trecuteHtml += realizareRow({
        iconWrapClass: 'gray',
        icon: '📅',
        title: `Top 10 lunar — Locul ${t.pozitie}`,
        meta: `${baltaNume} · ${lunaFmt}${t.kg_total ? ' · ' + parseFloat(t.kg_total).toFixed(1) + ' kg' : ''}`,
        star: false,
        date: '',
        trecut: true,
        link: null,
      });
    });

  activeList.innerHTML  = activeHtml;
  trecuteList.innerHTML = trecuteHtml;

  if (!activeHtml)  document.getElementById('active-empty').style.display  = 'block';
  if (!trecuteHtml) document.getElementById('trecute-empty').style.display = 'block';
}

function showError(msg) {
  document.getElementById('loading-screen').style.display = 'none';
  document.getElementById('error-msg').textContent = msg;
  document.getElementById('error-screen').style.display = 'flex';
}

boot();
</script>
</body>
</html>
